<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wxc.aidata.server.business.mapper.BusinessSystemMapper">

    <resultMap id="BizSystemResultMap" type="com.wxc.aidata.server.business.entity.BizSystem">
        <id property="id" column="id"/>
        <result property="systemCode" column="system_code"/>
        <result property="systemName" column="system_name"/>
        <result property="baseUrl" column="base_url"/>
        <result property="authType" column="auth_type"/>
        <result property="authConfig" column="auth_config"/>
        <result property="connectTimeout" column="connect_timeout"/>
        <result property="readTimeout" column="read_timeout"/>
        <result property="status" column="status"/>
        <result property="description" column="description"/>
        <result property="createdBy" column="created_by"/>
        <result property="createdTime" column="created_time"/>
        <result property="updatedBy" column="updated_by"/>
        <result property="updatedTime" column="updated_time"/>
    </resultMap>

    <!-- 按名称、编码和状态筛选业务系统，PageHelper 负责追加分页 SQL。 -->
    <select id="findBusinessSystems" resultMap="BizSystemResultMap">
        SELECT
            id,
            system_code,
            system_name,
            base_url,
            auth_type,
            auth_config,
            connect_timeout,
            read_timeout,
            status,
            description,
            created_by,
            created_time,
            updated_by,
            updated_time
        FROM biz_system
        <where>
            <if test="query.systemName != null and query.systemName != ''">
                AND system_name LIKE CONCAT('%', #{query.systemName}, '%')
            </if>
            <if test="query.systemCode != null and query.systemCode != ''">
                AND system_code LIKE CONCAT('%', #{query.systemCode}, '%')
            </if>
            <if test="query.status != null">
                AND status = #{query.status}
            </if>
            <if test="query.admin == false">
                <choose>
                    <when test="query.roleIds != null and query.roleIds.size() > 0">
                        AND EXISTS (
                            SELECT 1
                            FROM biz_system_role bsr
                            WHERE bsr.system_id = biz_system.id
                              AND bsr.role_id IN
                              <foreach collection="query.roleIds" item="roleId" open="(" separator="," close=")">
                                  #{roleId}
                              </foreach>
                        )
                    </when>
                    <otherwise>
                        AND 1 = 0
                    </otherwise>
                </choose>
            </if>
        </where>
        ORDER BY updated_time DESC, id DESC
    </select>

    <!-- 新增前校验系统编码唯一性。 -->
    <select id="existsBySystemCode" resultType="boolean">
        SELECT COUNT(1) > 0
        FROM biz_system
        WHERE system_code = #{systemCode}
    </select>

    <!-- 编辑前校验除当前记录外的系统编码唯一性。 -->
    <select id="existsBySystemCodeExcludeId" resultType="boolean">
        SELECT COUNT(1) > 0
        FROM biz_system
        WHERE system_code = #{systemCode}
          AND id != #{id}
    </select>

    <!-- 查询业务系统可见角色。 -->
    <select id="findRoleIdsBySystemId" resultType="java.lang.Long">
        SELECT role_id
        FROM biz_system_role
        WHERE system_id = #{systemId}
        ORDER BY role_id
    </select>

    <!-- 删除业务系统旧角色范围。 -->
    <delete id="deleteRolesBySystemId">
        DELETE FROM biz_system_role
        WHERE system_id = #{systemId}
    </delete>

    <!-- 保存业务系统角色范围，roleIds 为空时由服务层跳过。 -->
    <insert id="insertSystemRoles">
        INSERT INTO biz_system_role (system_id, role_id)
        VALUES
        <foreach collection="roleIds" item="roleId" separator=",">
            (#{systemId}, #{roleId})
        </foreach>
    </insert>
</mapper>
