<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wxc.aidata.server.audit.mapper.AuditLogQueryMapper">

    <!-- 登录日志查询结果映射。 -->
    <resultMap id="LoginLogRowResultMap" type="com.wxc.aidata.server.audit.mapper.AuditLogQueryMapper$LoginLogRow">
        <constructor>
            <arg column="id" javaType="java.lang.Long"/>
            <arg column="user_id" javaType="java.lang.Long"/>
            <arg column="username" javaType="java.lang.String"/>
            <arg column="login_ip" javaType="java.lang.String"/>
            <arg column="user_agent" javaType="java.lang.String"/>
            <arg column="login_status" javaType="java.lang.String"/>
            <arg column="message" javaType="java.lang.String"/>
            <arg column="login_time" javaType="java.time.LocalDateTime"/>
        </constructor>
    </resultMap>

    <!-- 操作日志查询结果映射。 -->
    <resultMap id="OperationLogRowResultMap" type="com.wxc.aidata.server.audit.mapper.AuditLogQueryMapper$OperationLogRow">
        <constructor>
            <arg column="id" javaType="java.lang.Long"/>
            <arg column="request_id" javaType="java.lang.String"/>
            <arg column="user_id" javaType="java.lang.Long"/>
            <arg column="username" javaType="java.lang.String"/>
            <arg column="module_name" javaType="java.lang.String"/>
            <arg column="operation_name" javaType="java.lang.String"/>
            <arg column="request_method" javaType="java.lang.String"/>
            <arg column="request_path" javaType="java.lang.String"/>
            <arg column="request_ip" javaType="java.lang.String"/>
            <arg column="request_params" javaType="java.lang.String"/>
            <arg column="status" javaType="java.lang.String"/>
            <arg column="duration_ms" javaType="java.lang.Long"/>
            <arg column="error_message" javaType="java.lang.String"/>
            <arg column="created_time" javaType="java.time.LocalDateTime"/>
        </constructor>
    </resultMap>

    <!-- 按账号、状态和时间范围筛选登录日志。 -->
    <select id="findLoginLogs" resultMap="LoginLogRowResultMap">
        SELECT
            id,
            user_id,
            username,
            login_ip,
            user_agent,
            login_status,
            message,
            login_time
        FROM sys_login_log
        WHERE 1 = 1
        <if test="query.username != null and query.username != ''">
            AND username LIKE CONCAT('%', #{query.username}, '%')
        </if>
        <if test="query.loginStatus != null and query.loginStatus != ''">
            AND login_status = #{query.loginStatus}
        </if>
        <if test="query.startTime != null">
            AND login_time &gt;= #{query.startTime}
        </if>
        <if test="query.endTime != null">
            AND login_time &lt;= #{query.endTime}
        </if>
        ORDER BY login_time DESC, id DESC
    </select>

    <!-- 按用户、路径、状态和时间范围筛选操作日志。 -->
    <select id="findOperationLogs" resultMap="OperationLogRowResultMap">
        SELECT
            id,
            request_id,
            user_id,
            username,
            module_name,
            operation_name,
            request_method,
            request_path,
            request_ip,
            request_params,
            status,
            duration_ms,
            error_message,
            created_time
        FROM sys_operation_log
        WHERE 1 = 1
        <if test="query.username != null and query.username != ''">
            AND username LIKE CONCAT('%', #{query.username}, '%')
        </if>
        <if test="query.requestPath != null and query.requestPath != ''">
            AND request_path LIKE CONCAT('%', #{query.requestPath}, '%')
        </if>
        <if test="query.status != null and query.status != ''">
            AND status = #{query.status}
        </if>
        <if test="query.startTime != null">
            AND created_time &gt;= #{query.startTime}
        </if>
        <if test="query.endTime != null">
            AND created_time &lt;= #{query.endTime}
        </if>
        ORDER BY created_time DESC, id DESC
    </select>
</mapper>
